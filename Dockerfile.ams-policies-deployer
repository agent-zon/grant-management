# Build context: gen/policies (produced when AMS content deployer is configured, e.g. @sap/ams + cds build).
FROM node:22-bookworm-slim

WORKDIR /app

COPY package*.json ./
RUN if [ -f package-lock.json ]; then npm ci --omit=dev --ignore-scripts; else npm install --omit=dev --ignore-scripts; fi

COPY . ./

# Numeric UID required: Kyma content-deployment Job uses runAsNonRoot; non-numeric USER (e.g. "node") fails CreateContainerConfigError.
RUN chown -R 1000:1000 /app
USER 1000:1000

CMD ["npm", "start"]
