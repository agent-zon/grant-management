apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: 
    server: https://api.c-127c9ef.stage.kyma.ondemand.com
  name: scai
contexts:
- context:
    cluster: scai
    namespace: grants
    user: scai
  name: scai
current-context: scai
kind: Config
preferences: {}
users:
- name: scai
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      args:
      - get-token
      - --oidc-issuer-url=https://kymacanary.accounts.ondemand.com
      - --oidc-client-id=d25a1572-20e8-486f-9a6d-fe36734c4f6d
      - --oidc-extra-scope=email
      - --oidc-extra-scope=openid
      command: kubectl-oidc_login
      env: null
      installHint: |
        kubelogin plugin is required to proceed with authentication
        # Homebrew (macOS and Linux)
        brew install int128/kubelogin/kubelogin
        # Krew (macOS, Linux, Windows and ARM)
        kubectl krew install oidc-login
        # Chocolatey (Windows)
        choco install kubelogin
      interactiveMode: IfAvailable
      provideClusterInfo: false
