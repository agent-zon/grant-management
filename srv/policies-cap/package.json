{
  "name": "policies-cap",
  "version": "1.0.0",
  "description": "Minimal CAP application for AI Agent Policies Management",
  "main": "index.js",
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build",
    "deploy": "cds deploy",
    "test": "node tests/test-runner.js",
    "test:unit": "node tests/test-runner.js --unit-only",
    "test:integration": "node tests/test-runner.js --integration",
    "test:validate": "node tests/test-runner.js --validate",
    "test:field-naming": "node tests/test-runner.js"
  },
  "dependencies": {
    "@sap/cds": "^8",
    "@sap/xssec": "^3",
    "dotenv": "^17.2.3",
    "express": "^4",
    "js-yaml": "^4.1.1",
    "sqlite3": "^5"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "policies.db"
        }
      },
      "auth": {
        "kind": "dummy"
      }
    },
    "serve": {
      "from": "./srv"
    },
    "build": {
      "target": "gen"
    },
    "deploy": {
      "kind": "k8s"
    },
    "profile": "production"
  }
}
