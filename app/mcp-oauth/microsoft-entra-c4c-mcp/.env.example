# Copy to .env and fill in. Do not commit .env (secrets).
# For local run: source .env && python mcp_oauth.py
# For Kyma: use create-secret-from-env.sh to create Secret from .env
#
# Redirect URI in Azure: http://localhost:8000/auth/callback (local) or https://<your-apirule-host>/auth/callback (Kyma)

export STATE_SECRET=your-random-secret-for-oauth-state
export FASTMCP_OAUTH_ENCRYPTION_KEY=your-base64-encryption-key
export OAUTH_PROVIDER_NAME=microsoft
export OAUTH_CLIENT_ID=your-azure-app-client-id
export OAUTH_CLIENT_SECRET=your-azure-app-client-secret
export OAUTH_AUTHORIZE_ENDPOINT=https://login.microsoftonline.com/YOUR_TENANT_ID/oauth2/v2.0/authorize
export OAUTH_TOKEN_ENDPOINT=https://login.microsoftonline.com/YOUR_TENANT_ID/oauth2/v2.0/token
export OAUTH_SCOPES="openid email profile offline_access User.Read"
export OAUTH_ISSUER=https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
export OAUTH_JWKS_ENDPOINT=https://login.microsoftonline.com/YOUR_TENANT_ID/discovery/v2.0/keys

# Optional: downstream MCP server URL (proxied after OAuth)
export MCP_URL=https://v0-mock-mcp-server.vercel.app/mcp
